# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Auth (NextAuth)
# Local: http://localhost:3000 | Production: set to your exact app URL (e.g. https://digitproperties.com)
# For social login: in Google Cloud Console add Authorized redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
# NEXTAUTH_SECRET is required in production; if missing, OAuth may redirect with error=OAuthCallback
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_hex_32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# Same numeric Meta App ID as FACEBOOK_CLIENT_ID — enables reliable Facebook share on mobile (Share Dialog). Optional.
NEXT_PUBLIC_FACEBOOK_APP_ID=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# Flutterwave
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# Paystack
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# FCM (Firebase)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Resend (transactional emails)
RESEND_API_KEY=re_xxxxxxxxxxxx
# Where admin notifications go (new user, claims, verification requests, etc.). Use your real inbox so mail is delivered.
# If contact@ forwards to Gmail but app emails don't arrive, set this to your Gmail so Resend sends directly (avoids forwarding/spam).
ADMIN_EMAIL=fabhainternation@gmail.com
# Optional: contact form only. Defaults to ADMIN_EMAIL. Set if you want contact form to a different address.
# CONTACT_FORM_TO=fabhainternation@gmail.com
# Optional: default noreply@digitproperties.com (must use verified Resend domain)
FROM_EMAIL=Digit Properties <noreply@digitproperties.com>
# Use until domain is verified (no DNS): Digit Properties <onboarding@resend.dev>
# RESEND_FROM_OVERRIDE=Digit Properties <onboarding@resend.dev>

# Geocoding (new listing map). Optional: use Google for better address results. Enable Geocoding API and add key:
# GOOGLE_GEOCODING_API_KEY=your_key
# GOOGLE_MAPS_API_KEY=your_key

# reCAPTCHA v2 Checkbox (contact form). Create at https://www.google.com/recaptcha/admin → “reCAPTCHA v2” → “I'm not a robot” Checkbox. Add your domains (e.g. localhost for dev, your production domain).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Phone verification – Twilio Verify (SMS or WhatsApp). Default: SMS. Set TWILIO_VERIFY_CHANNEL=whatsapp when approved.
# Create a Verify Service in Twilio Console. For SMS no extra sender needed; for WhatsApp add a WhatsApp Sender.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
# sms (default) | whatsapp. Use sms until WhatsApp Business profile is approved.
# TWILIO_VERIFY_CHANNEL=sms

# Termii – SMS verification (primary for Nigeria). Message: "Your Digit Properties Verification Pin is XXXXXX. It expires in 30 minutes."
# Required for Termii:
TERMII_API_KEY=your_termii_api_key_from_dashboard
TERMII_SENDER_ID=DigitProp
# Optional: dnd = SMS (default). TERMII_BASE_URL defaults to https://api.termii.com
# TERMII_CHANNEL=dnd
# TERMII_BASE_URL=https://api.termii.com

# App
# Local: http://localhost:3000 | Production: https://digitproperties.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Digit Properties
